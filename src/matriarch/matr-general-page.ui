                    </child>
                    <property name="title" translatable="yes">Paraphony Mode</property>
                    <property name="model">
                      <object class="ScControlValueList">
                        <items>
                          <item>Mono (default)</item>
                          <item>Duo</item>
                          <item>Quad</item>
                        </items>
                      </object>
                    </property>
                  </object>
                </child>

                <child>
                  <object class="ScComboRow">
                    <child>
                      <object class="MatrControl">
                        <property name="id">56</property>
                      </object>
                    </child>
                    <property name="title" translatable="yes">Paraphonic Unison</property>
                    <property name="model">
                      <object class="ScControlValueList">
                        <items>
                          <item>Off (default)</item>
                          <item>On</item>
                        </items>
                      </object>
                    </property>
                  </object>
