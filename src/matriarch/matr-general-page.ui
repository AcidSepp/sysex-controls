                <child>
                  <object class="ScComboRow">
                    <child>
                      <object class="MatrControl">
                        <property name="id">2</property>
                      </object>
                    </child>
                    <property name="title" translatable="yes">Knob Mode</property>
                    <property name="model">
                      <object class="ScControlValueList">
                        <items>
                          <item>Snap</item>
                          <item>Pass-Thru</item>
                          <item>Relative (default)</item>
                        </items>
                      </object>
                    </property>
                  </object>
                </child>
                <child>
                  <object class="ScComboRow">
                    <child>
                      <object class="MatrControl">
                        <property name="id">3</property>
                      </object>
                    </child>
                    <property name="title" translatable="yes">Note Priority</property>
                    <property name="model">
                      <object class="ScControlValueList">
                        <items>
                          <item>Low</item>
                          <item>High</item>
                          <item>Last Note (default)</item>
                        </items>
                      </object>
                    </property>
                  </object>
                </child>
                <child>
                  <object class="ScComboRow">
                    <child>
                      <object class="MatrControl">
                        <property name="id">16</property>
                      </object>
                    </child>
                    <property name="title" translatable="yes">Local Control: Keys</property>
                    <property name="model">
                      <object class="ScControlValueList">
                        <items>
                          <item>Off</item>
                          <item>On (default)</item>
                        </items>
                      </object>
                    </property>
                  </object>
                </child>
                <child>
                  <object class="ScComboRow">
                    <child>
                      <object class="MatrControl">
                        <property name="id">17</property>
                      </object>
                    </child>
                    <property name="title" translatable="yes">Local Control: Wheels</property>
                    <property name="model">
                      <object class="ScControlValueList">
                        <items>
                          <item>Off</item>
                          <item>On (default)</item>
                        </items>
                      </object>
                    </property>
                  </object>
                </child>
                <child>
                  <object class="ScComboRow">
                    <child>
                      <object class="MatrControl">
                        <property name="id">18</property>
                      </object>
                    </child>
                    <property name="title" translatable="yes">Local Control: Panel</property>
                    <property name="model">
                      <object class="ScControlValueList">
                        <items>
                          <item>Off</item>
                          <item>On (default)</item>
                        </items>
                      </object>
                    </property>
                  </object>
                </child>
                <child>
                  <object class="ScComboRow">
                    <child>
                      <object class="MatrControl">
                        <property name="id">19</property>
                      </object>
                    </child>
                    <property name="title" translatable="yes">Local Control: Arp/Seq</property>
                    <property name="model">
                      <object class="ScControlValueList">
                        <items>
                          <item>Off</item>
                          <item>On (default)</item>
                        </items>
                      </object>
                    </property>
                  </object>
                </child>

