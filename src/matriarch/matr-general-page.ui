                    </child>
                    <property name="title" translatable="yes">Mod Oscillator Square Wave Polarity</property>
                    <property name="model">
                      <object class="ScControlValueList">
                        <items>
                          <item>Unipolar</item>
                          <item>Bipolar (default)</item>
                        </items>
                      </object>
                    </property>
                  </object>
                </child>

