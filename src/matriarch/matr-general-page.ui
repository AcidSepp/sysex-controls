                <child>
                  <object class="ScChRow">
                    <child>
                      <object class="MatrControl">
                        <property name="id">38</property>
                      </object>
                    </child>
                    <property name="title" translatable="yes">Keyboard Octave Transpose</property>
                    <property name="model">
                      <object class="ScControlValueList">
                        <items>
                          <item>-2</item>
                          <item>-1</item>
                          <item>0 (default)</item>
                          <item>+1</item>
                          <item>+2</item>
                        </items>
                      </object>
                    </property>
                  </object>
                </child>

                <child>
                  <object class="ScComboRow">
                    <child>
                      <object class="MatrControl">
                        <property name="id">39</property>
                      </object>
                    </child>
                    <property name="title" translatable="yes">Delayed KB Octave Transpose</property>
                    <property name="model">
                      <object class="ScControlValueList">
                        <items>
                          <item>Off</item>
                          <item>On (default)</item>
                        </items>
                      </object>
                    </property>
                  </object>
                </child>

                <child>
                  <object class="ScComboRow">
                    <child>
                      <object class="MatrControl">
                        <property name="id">40</property>
                      </object>
                    </child>
                    <property name="title" translatable="yes">Glide Type</property>
                    <property name="model">
                      <object class="ScControlValueList">
                        <items>
                          <item>Linear Constant Rate (default)</item>
                          <item>Linear Constant Time</item>
                          <item>Exponential</item>
                        </items>
                      </object>
                    </property>
                  </object>
                </child>

                <child>
                  <object class="ScComboRow">
                    <child>
                      <object class="MatrControl">
                        <property name="id">41</property>
                      </object>
                    </child>
                    <property name="title" translatable="yes">Gated Glide</property>
                    <property name="model">
                      <object class="ScControlValueList">
                        <items>
                          <item>Off</item>
                          <item>On (default)</item>
                        </items>
                      </object>
                    </property>
                  </object>
                </child>

                <child>
                  <object class="ScComboRow">
                    <child>
                      <object class="MatrControl">
                        <property name="id">42</property>
                      </object>
                    </child>
                    <property name="title" translatable="yes">Legato Glide</property>
                    <property name="model">
                      <object class="ScControlValueList">
                        <items>
                          <item>Off</item>
                          <item>On (default)</item>
                        </items>
                      </object>
                    </property>
                  </object>
                </child>

